# CasaControl — copy to `.env` and fill in what you use.
# NOTE: values needed at runtime on-device are read via app config / SecureStore,
# not bundled secrets. Keep real secrets out of git (this file has none).

# --- Spotify (Authorization Code + PKCE, no client secret needed) ---
# Create an app at https://developer.spotify.com/dashboard and add the redirect
# URIs casacontrol://callback and casacontrol-hub://callback.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=

# --- Claude assistant (optional) ---
# Anthropic API key. For personal use it can live in SecureStore (Settings);
# this is a convenience for local dev only. Never ship a raw key in a public build.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# --- PS5 (set on the TABLET; MAC is required for Wake-on-LAN) ---
EXPO_PUBLIC_PS5_MAC=
EXPO_PUBLIC_PS5_IP=
EXPO_PUBLIC_LAN_BROADCAST=192.168.1.255

# --- UE BOOM Bluetooth speaker (set on the TABLET; BLE power on/off) ---
# The speaker's BLE id — discover it via the hub route GET /ble/discover.
EXPO_PUBLIC_UE_BOOM_MAC=
# The tablet's own Bluetooth MAC, which must be PAIRED with the BOOM. The UE
# power command embeds a paired controller's MAC. Find it in the tablet's
# Bluetooth / About settings.
EXPO_PUBLIC_TABLET_BT_MAC=
# Optional: pin Spotify playback to a Connect device by its exact name.
EXPO_PUBLIC_SPOTIFY_DEVICE_NAME=

# --- Default hub addresses (set on the PHONE; also editable in-app Settings) ---
EXPO_PUBLIC_HUB_LOCAL_IP=192.168.1.50
EXPO_PUBLIC_HUB_TAILSCALE_IP=100.100.100.100

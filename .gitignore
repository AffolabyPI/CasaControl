# Dependencies
node_modules/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases

# Expo
.expo/
dist/
web-build/
*.orig.*

# Native projects (regenerated by `expo prebuild`) and build artifacts
/android
/ios
apps/*/android/
apps/*/ios/
# Local Expo modules: keep the source, drop native build output
apps/*/modules/*/android/build/
apps/*/modules/*/android/.cxx/
*.apk
*.aab
*.ipa
*.keystore

# TypeScript
*.tsbuildinfo

# Environment / secrets
.env
.env.*
!.env.example
google-services.json
GoogleService-Info.plist

# Metro
.metro-health-check*

# Local tooling / editor
.claude/
.idea/
.vscode/*
!.vscode/extensions.json

# Logs & OS
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
.DS_Store
Thumbs.db

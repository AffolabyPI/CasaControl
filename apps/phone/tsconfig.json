{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@casacontrol/shared": ["../../packages/shared/src/index.ts"],
      "@casacontrol/shared/*": ["../../packages/shared/src/*"]
